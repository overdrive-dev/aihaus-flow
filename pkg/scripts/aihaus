#!/usr/bin/env bash
# aihaus — global CLI verb shim  M022/Z5  FR-09/FR-11/FR-12; ADR-260504-A §6.1
# AIHAUS_HOME: 8-tier priority chain inlined (D-Z5-A; sourcing install.sh unsafe).
# self-update → update.sh --self  (Z9 implements --self flag; runtime fail until Z9 ships)
# update --all → $HOME/.aihaus/.targets registry (Z9 writes on install; degrades if absent)
set -euo pipefail

_resolve() {
  # tier 2: AIHAUS_HOME env var
  [[ -n "${AIHAUS_HOME:-}" ]] && [[ -d "${AIHAUS_HOME}/pkg/.aihaus/skills" ]] && \
    printf '%s' "${AIHAUS_HOME}" && return
  # tier 3: ~/.aihaus/.install-source registry
  local reg="$HOME/.aihaus/.install-source" r
  if [[ -f "${reg}" ]]; then
    r="$(head -n1 "${reg}" | tr -d '[:space:]')"
    [[ -n "${r}" ]] && [[ -d "${r}/pkg/.aihaus/skills" ]] && printf '%s' "${r}" && return
  fi
  # tiers 4-8: scan candidates; pick newest HEAD commit timestamp
  local xdg="${XDG_DATA_HOME:-$HOME/.local/share}" best="" best_ts=0 c ts
  for c in "${xdg}/aihaus" "$HOME/tools/aihaus" \
            "$HOME/Documents/GitHub/aihaus-flow" \
            "$HOME/Documents/GitHub/aihaus" "$HOME/code/aihaus"; do
    [[ -d "${c}/pkg/.aihaus/skills" ]] && [[ -d "${c}/.git" ]] || continue
    ts="$(git -C "${c}" log -1 --format=%ct 2>/dev/null || echo 0)"
    [[ "${ts}" -gt "${best_ts}" ]] && best="${c}" && best_ts="${ts}"
  done
  [[ -n "${best}" ]] && mkdir -p "$HOME/.aihaus" && \
    printf '%s\n' "${best}" > "${reg}" && printf '%s' "${best}" && return
  return 1
}

_dogfood_dirty() {  # FR-12/R8: abort (no stash) on dirty dogfood cwd
  [[ -f "${PWD}/pkg/scripts/install.sh" ]] && [[ -d "${PWD}/pkg/.aihaus/skills" ]] || return 0
  [[ -n "$(git -C "${PWD}" status --porcelain 2>/dev/null)" ]] || return 0
  echo "aihaus self-update: dogfood cwd has uncommitted changes — aborting (commit or stash manually first)" >&2
  exit 3
}

_help() { cat <<'EOF'
Usage: aihaus <verb> [options]
Verbs:
  install       Install aihaus into the current directory
  update        Update aihaus in the current directory
  memory        Query repository memory (delegates to aih-graph)
                memory packet --task "<text>" --json — batched context packet
                (status + Rule/Decision slice + top matches in ONE call; M050/S05)
  prefs add "<text>" [--topic <slug>]
                Append a global user preference (tier C, M050/S06) to
                ~/.aihaus/memory/user/preferences.md — the SOLE write path
                (ADR-260611-C). Topics: workflow|style|tooling|communication|other
  update --all  Update all registered installs (requires Z9 registry)
  self-update   Update the central aihaus clone from origin (requires Z9)
  --help, -h    Show this message
EOF
}

# ---------------------------------------------------------------------------
# memory packet (M050/S05, ADR-260611-F) — single batched invocation chain.
# Composes three aih-graph calls into ONE shim call so the SubagentStart hook
# makes exactly one `aihaus memory packet` invocation (12s internal hook
# timeout / 15s settings belt). Output shape (architecture.md §4.4):
#   {"status":<status --json>,"rules":<query --types Rule,Decision --top 5>,
#    "matches":<query --top 3>,"degraded":bool,"elapsed_ms":N}
# ---------------------------------------------------------------------------
declare -a GRAPH_RUN=()

_resolve_graph_run() {  # mirrors _memory discovery chain, without exec
  GRAPH_RUN=()
  local ext="" c
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) ext=".exe" ;;
  esac
  local candidates=()
  [[ -n "${AIH_GRAPH_BIN:-}" ]] && candidates+=("${AIH_GRAPH_BIN}")
  candidates+=("$PWD/.aihaus/bin/aih-graph${ext}")
  for c in "${candidates[@]}"; do
    [[ -x "${c}" ]] && GRAPH_RUN=("${c}") && return 0
  done
  if [[ -f "${AIHAUS_HOME}/aih-graph/go.mod" ]] && command -v go >/dev/null 2>&1; then
    local go_tmp_root="${AIH_GRAPH_GO_TMP:-${AIHAUS_HOME}/tmp/aih-graph-go}"
    mkdir -p "${go_tmp_root}/tmp" "${go_tmp_root}/cache" 2>/dev/null || true
    export AIH_GRAPH_CALLER_CWD="${PWD}"
    export GOTMPDIR="${go_tmp_root}/tmp"
    export GOCACHE="${go_tmp_root}/cache"
    GRAPH_RUN=(go -C "${AIHAUS_HOME}/aih-graph" run ./cmd/aih-graph)
    return 0
  fi
  [[ -x "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" ]] && \
    GRAPH_RUN=("${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}") && return 0
  [[ -x "$HOME/.aihaus/bin/aih-graph${ext}" ]] && \
    GRAPH_RUN=("$HOME/.aihaus/bin/aih-graph${ext}") && return 0
  command -v aih-graph >/dev/null 2>&1 && GRAPH_RUN=(aih-graph) && return 0
  return 1
}

_now_ms() {
  local t
  t="$(date +%s%3N 2>/dev/null || echo "")"
  [[ "$t" =~ ^[0-9]+$ ]] || t=$(( $(date +%s 2>/dev/null || echo 0) * 1000 ))
  printf '%s' "$t"
}

_memory_packet() {
  # Receives the db-pinned graph args minus the leading verb.
  local task="" db="" repo=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task)   task="${2:-}"; shift 2 || break ;;
      --task=*) task="${1#--task=}"; shift ;;
      --db|-db)   db="${2:-}"; shift 2 || break ;;
      --db=*)   db="${1#--db=}"; shift ;;
      -db=*)    db="${1#-db=}"; shift ;;
      --repo)   repo="${2:-}"; shift 2 || break ;;
      --repo=*) repo="${1#--repo=}"; shift ;;
      --json)   shift ;;  # packet output is always JSON
      *)        shift ;;
    esac
  done
  if [[ -z "${task}" ]]; then
    echo 'aihaus memory packet: --task "<text>" required' >&2
    exit 2
  fi
  [[ -z "${repo}" ]] && repo="${AIH_GRAPH_REPO:-${CLAUDE_PROJECT_DIR:-$PWD}}"
  _resolve_graph_run || {
    echo "aihaus memory: aih-graph not found. Install it with: bash pkg/scripts/install-aih-graph-binary.sh" >&2
    exit 1
  }
  local db_args=()
  [[ -n "${db}" ]] && db_args=(--db "${db}")
  local start_ms end_ms degraded="false"
  local status_json rules_json matches_json
  start_ms="$(_now_ms)"
  status_json="$("${GRAPH_RUN[@]}" status --repo "${repo}" "${db_args[@]}" --json 2>/dev/null || true)"
  rules_json="$("${GRAPH_RUN[@]}" query --repo "${repo}" "${db_args[@]}" --types Rule,Decision --top 5 --json "${task}" 2>/dev/null || true)"
  matches_json="$("${GRAPH_RUN[@]}" query --repo "${repo}" "${db_args[@]}" --top 3 --json "${task}" 2>/dev/null || true)"
  end_ms="$(_now_ms)"
  # Defensive: any sub-payload that is empty or non-JSON degrades to {}.
  case "${status_json}" in  "{"*) : ;; *) status_json='{}';  degraded="true" ;; esac
  case "${rules_json}" in   "{"*) : ;; *) rules_json='{}';   degraded="true" ;; esac
  case "${matches_json}" in "{"*) : ;; *) matches_json='{}'; degraded="true" ;; esac
  printf '{"status":%s,"rules":%s,"matches":%s,"degraded":%s,"elapsed_ms":%s}\n' \
    "${status_json}" "${rules_json}" "${matches_json}" "${degraded}" "$(( end_ms - start_ms ))"
  exit 0
}

_memory() {
  local ext="" c bin=""
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) ext=".exe" ;;
  esac
  local graph_args=("$@")
  if [[ $# -gt 0 ]]; then
    local cmd="$1"
    shift
    case "$cmd" in
      build|refresh|status|query|context|callers|impact|gotchas|milestone|rule|why|rule-drift|obsidian-export|export-obsidian|packet)
        # db-pin allowlist (BR-P3): every query verb pins --db to the repo DB
        # unless the caller passed one. --user scope is exempt — the user-scope
        # graph lives at ~/.aihaus/state/user-graph.db (ADR-260611-E), never
        # the per-repo DB. `packet` (M050/S05) joins the allowlist to inherit
        # --db defaulting, then is intercepted below (shim-composed verb —
        # aih-graph itself does not know it).
        local has_db=0 user_scope=0 arg repo_root db_path
        for arg in "$@"; do
          [[ "$arg" == "--db" || "$arg" == "-db" || "$arg" == --db=* || "$arg" == -db=* ]] && has_db=1
          [[ "$arg" == "--user" ]] && user_scope=1
        done
        if [[ "$has_db" == "0" && "$user_scope" == "0" ]]; then
          repo_root="${AIH_GRAPH_REPO:-${CLAUDE_PROJECT_DIR:-$PWD}}"
          local expect_repo=0
          for arg in "$@"; do
            if [[ "$expect_repo" == "1" ]]; then
              repo_root="$arg"
              expect_repo=0
              continue
            fi
            case "$arg" in
              --repo) expect_repo=1 ;;
              --repo=*) repo_root="${arg#--repo=}" ;;
            esac
          done
          db_path="${repo_root}/.aihaus/state/aih-graph.db"
          mkdir -p "$(dirname "$db_path")" 2>/dev/null || true
          graph_args=("$cmd" --db "$db_path" "$@")
        else
          graph_args=("$cmd" "$@")
        fi
        ;;
      *)
        graph_args=("$cmd" "$@")
        ;;
    esac
  fi
  # M050/S05: `packet` is composed by the shim (ONE shim call → three
  # aih-graph invocations), never forwarded to the binary.
  if [[ "${graph_args[0]:-}" == "packet" ]]; then
    _memory_packet "${graph_args[@]:1}"
  fi
  local candidates=()
  [[ -n "${AIH_GRAPH_BIN:-}" ]] && candidates+=("${AIH_GRAPH_BIN}")
  candidates+=("$PWD/.aihaus/bin/aih-graph${ext}")
  for c in "${candidates[@]}"; do
    if [[ -x "${c}" ]]; then
      bin="${c}"
      break
    fi
  done
  if [[ -n "${bin}" ]]; then
    exec "${bin}" "${graph_args[@]}"
  fi
  if [[ -f "${AIHAUS_HOME}/aih-graph/go.mod" ]] && command -v go >/dev/null 2>&1; then
    local go_tmp_root="${AIH_GRAPH_GO_TMP:-${AIHAUS_HOME}/tmp/aih-graph-go}"
    mkdir -p "${go_tmp_root}/tmp" "${go_tmp_root}/cache" 2>/dev/null || true
    AIH_GRAPH_CALLER_CWD="${PWD}" \
      GOTMPDIR="${go_tmp_root}/tmp" \
      GOCACHE="${go_tmp_root}/cache" \
      exec go -C "${AIHAUS_HOME}/aih-graph" run ./cmd/aih-graph "${graph_args[@]}"
  fi
  if [[ -x "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" ]]; then
    exec "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" "${graph_args[@]}"
  fi
  if [[ -x "$HOME/.aihaus/bin/aih-graph${ext}" ]]; then
    exec "$HOME/.aihaus/bin/aih-graph${ext}" "${graph_args[@]}"
  fi
  if command -v aih-graph >/dev/null 2>&1; then
    exec aih-graph "${graph_args[@]}"
  fi
  echo "aihaus memory: aih-graph not found. Install it with: bash pkg/scripts/install-aih-graph-binary.sh" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# prefs (M050/S06, ADR-260611-C/E) — tier-C global user preferences.
# `aihaus prefs add "<text>" [--topic <slug>]` is the SOLE write path to
# ~/.aihaus/memory/user/preferences.md (BR-P7 — file-guard keeps blocking
# direct agent Write/Edit; no carve-outs). Atomicity: mkdir-based lock +
# temp file + atomic mv. Own audit JSONL (~/.aihaus/state/prefs-audit.jsonl,
# sole writer — BR-P5). Entry grammar (validated before append):
#   - PREF-<n> [YYYY-MM-DD] (<workflow|style|tooling|communication|other>) <text>
# PREF-<n> allocated by max-scan (business-rules-migrate.sh BR-id shape).
# ---------------------------------------------------------------------------
_PREFS_TS() { date -u +%FT%TZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z"; }

_prefs_audit() {  # _prefs_audit <result> <id> <topic> <reason>
  local audit_dir="$HOME/.aihaus/state"
  local audit_file="${audit_dir}/prefs-audit.jsonl"
  local r_result="${1:-}" r_id="${2:-}" r_topic="${3:-}" r_reason="${4:-}"
  r_reason="${r_reason//\\/\\\\}"; r_reason="${r_reason//\"/\\\"}"
  mkdir -p "${audit_dir}" 2>/dev/null || return 0
  printf '{"ts":"%s","event":"prefs-add","result":"%s","id":"%s","topic":"%s","reason":"%s","shell":"bash"}\n' \
    "$(_PREFS_TS)" "${r_result}" "${r_id}" "${r_topic}" "${r_reason}" \
    >> "${audit_file}" 2>/dev/null || true
}

_prefs_add() {
  local text="" topic="other" arg
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --topic)   topic="${2:-}"; shift 2 || break ;;
      --topic=*) topic="${1#--topic=}"; shift ;;
      *)
        if [[ -z "${text}" ]]; then text="$1"; else text="${text} $1"; fi
        shift ;;
    esac
  done

  # --- Format validation (refusal = non-zero exit + audit row) ---
  # Trim leading/trailing whitespace (pure bash).
  text="${text#"${text%%[![:space:]]*}"}"
  text="${text%"${text##*[![:space:]]}"}"
  if [[ -z "${text}" ]]; then
    _prefs_audit "refused" "" "${topic}" "empty entry text"
    echo 'aihaus prefs add: entry text is empty. Usage: aihaus prefs add "<text>" [--topic <slug>]' >&2
    exit 2
  fi
  case "${text}" in
    *$'\n'*|*$'\r'*)
      _prefs_audit "refused" "" "${topic}" "multi-line entry text"
      echo "aihaus prefs add: entry must be a single line (no embedded newlines)." >&2
      exit 2 ;;
  esac
  if [[ "${#text}" -gt 500 ]]; then
    _prefs_audit "refused" "" "${topic}" "entry text exceeds 500 chars (${#text})"
    echo "aihaus prefs add: entry text exceeds 500 characters (${#text})." >&2
    exit 2
  fi
  case "${topic}" in
    workflow|style|tooling|communication|other) : ;;
    *)
      _prefs_audit "refused" "" "${topic}" "invalid topic (allowed: workflow|style|tooling|communication|other)"
      echo "aihaus prefs add: invalid --topic '${topic}' (allowed: workflow|style|tooling|communication|other)." >&2
      exit 2 ;;
  esac

  local prefs_file="$HOME/.aihaus/memory/user/preferences.md"
  local lock_dir="${prefs_file}.lock"
  mkdir -p "$(dirname "${prefs_file}")" 2>/dev/null || true

  # --- mkdir-based lock (atomic on every POSIX fs; ~10s timeout) ---
  local waited=0
  while ! mkdir "${lock_dir}" 2>/dev/null; do
    waited=$((waited + 1))
    if [[ "${waited}" -ge 100 ]]; then
      _prefs_audit "refused" "" "${topic}" "lock timeout at ${lock_dir}"
      echo "aihaus prefs add: could not acquire lock at ${lock_dir} (stale lock? remove the directory manually and retry)." >&2
      exit 3
    fi
    sleep 0.1 2>/dev/null || sleep 1
  done
  # shellcheck disable=SC2064
  trap "rmdir '${lock_dir}' 2>/dev/null || true" EXIT

  # Seed create-if-absent INSIDE the lock (concurrent first-adds race-safe).
  if [[ ! -f "${prefs_file}" ]]; then
    if [[ -f "${AIHAUS_HOME}/pkg/.aihaus/templates/user-preferences-global.md" ]]; then
      cp "${AIHAUS_HOME}/pkg/.aihaus/templates/user-preferences-global.md" "${prefs_file}" 2>/dev/null || true
    fi
    if [[ ! -f "${prefs_file}" ]]; then
      printf '# User Preferences (aihaus tier C)\n\n<!-- AIHAUS:PREFS-START -->\n## Preferences\n<!-- AIHAUS:PREFS-END -->\n' > "${prefs_file}"
    fi
  fi

  # PREF-<n> max-scan allocation (business-rules-migrate.sh shape).
  local _max next_id
  _max="$(grep -oE '^- PREF-[0-9]+' "${prefs_file}" 2>/dev/null | grep -oE '[0-9]+' | sort -n | tail -1 || true)"
  next_id=$(( ${_max:-0} + 1 ))
  local entry_date entry_line
  entry_date="$(date -u +%F 2>/dev/null || echo 1970-01-01)"
  entry_line="- PREF-${next_id} [${entry_date}] (${topic}) ${text}"

  # Temp file in the same directory + atomic mv. Insert before the END marker
  # when present; append at EOF otherwise.
  local tmp_file="${prefs_file}.tmp.$$"
  if awk -v entry="${entry_line}" '
    index($0, "<!-- AIHAUS:PREFS-END -->") > 0 && !done { print entry; done=1 }
    { print }
    END { if (!done) print entry }
  ' "${prefs_file}" > "${tmp_file}" 2>/dev/null && [[ -s "${tmp_file}" ]]; then
    mv -f "${tmp_file}" "${prefs_file}"
  else
    rm -f "${tmp_file}" 2>/dev/null || true
    rmdir "${lock_dir}" 2>/dev/null || true
    trap - EXIT
    _prefs_audit "refused" "PREF-${next_id}" "${topic}" "temp-file write failed"
    echo "aihaus prefs add: failed to write ${prefs_file}." >&2
    exit 1
  fi

  rmdir "${lock_dir}" 2>/dev/null || true
  trap - EXIT
  _prefs_audit "ok" "PREF-${next_id}" "${topic}" ""
  echo "prefs: appended PREF-${next_id} (${topic}) to ~/.aihaus/memory/user/preferences.md"
  exit 0
}

_prefs() {
  local sub="${1:-}"; shift || true
  case "${sub}" in
    add) _prefs_add "$@" ;;
    *)
      echo 'aihaus prefs: unknown sub-verb. Usage: aihaus prefs add "<text>" [--topic <slug>]' >&2
      exit 2 ;;
  esac
}

VERB="${1:-}"; shift || true
case "${VERB}" in --help|-h|"") _help; exit 0 ;; esac

AIHAUS_HOME="$(_resolve)" || { echo "aihaus: package not found. Set AIHAUS_HOME or reinstall." >&2; exit 1; }
export AIHAUS_HOME

case "${VERB}" in
  install)
    exec bash "${AIHAUS_HOME}/pkg/scripts/install.sh" --target "${PWD}" "$@" ;;
  update)
    if [[ "${1:-}" == "--all" ]]; then shift
      reg="$HOME/.aihaus/.targets"
      if [[ ! -f "${reg}" ]]; then
        echo "aihaus update --all: registry not yet populated (~/.aihaus/.targets; written by Z9 on next install)." >&2
        exit 1; fi
      rc=0
      while IFS= read -r t || [[ -n "${t}" ]]; do
        [[ -z "${t}" ]] && continue
        echo "aihaus update: ${t}"
        bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --target "${t}" "$@" || rc=$?
      done < "${reg}"; exit "${rc}"
    fi
    exec bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --target "${PWD}" "$@" ;;
  memory)
    _memory "$@" ;;
  prefs)
    _prefs "$@" ;;
  self-update)
    _dogfood_dirty
    exec bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --self "$@" ;;
  *)
    echo "aihaus: unknown verb '${VERB}'" >&2; echo "Run 'aihaus --help' for usage." >&2; exit 2 ;;
esac
