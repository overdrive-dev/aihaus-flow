#!/usr/bin/env bash
# aihaus — global CLI verb shim  M022/Z5  FR-09/FR-11/FR-12; ADR-260504-A §6.1
# AIHAUS_HOME: 8-tier priority chain inlined (D-Z5-A; sourcing install.sh unsafe).
# self-update → update.sh --self  (Z9 implements --self flag; runtime fail until Z9 ships)
# update --all → $HOME/.aihaus/.targets registry (Z9 writes on install; degrades if absent)
set -euo pipefail

_resolve() {
  # tier 2: AIHAUS_HOME env var
  [[ -n "${AIHAUS_HOME:-}" ]] && [[ -d "${AIHAUS_HOME}/pkg/.aihaus/skills" ]] && \
    printf '%s' "${AIHAUS_HOME}" && return
  # tier 3: ~/.aihaus/.install-source registry
  local reg="$HOME/.aihaus/.install-source" r
  if [[ -f "${reg}" ]]; then
    r="$(head -n1 "${reg}" | tr -d '[:space:]')"
    [[ -n "${r}" ]] && [[ -d "${r}/pkg/.aihaus/skills" ]] && printf '%s' "${r}" && return
  fi
  # tiers 4-8: scan candidates; pick newest HEAD commit timestamp
  local xdg="${XDG_DATA_HOME:-$HOME/.local/share}" best="" best_ts=0 c ts
  for c in "${xdg}/aihaus" "$HOME/tools/aihaus" \
            "$HOME/Documents/GitHub/aihaus-flow" \
            "$HOME/Documents/GitHub/aihaus" "$HOME/code/aihaus"; do
    [[ -d "${c}/pkg/.aihaus/skills" ]] && [[ -d "${c}/.git" ]] || continue
    ts="$(git -C "${c}" log -1 --format=%ct 2>/dev/null || echo 0)"
    [[ "${ts}" -gt "${best_ts}" ]] && best="${c}" && best_ts="${ts}"
  done
  [[ -n "${best}" ]] && mkdir -p "$HOME/.aihaus" && \
    printf '%s\n' "${best}" > "${reg}" && printf '%s' "${best}" && return
  return 1
}

_dogfood_dirty() {  # FR-12/R8: abort (no stash) on dirty dogfood cwd
  [[ -f "${PWD}/pkg/scripts/install.sh" ]] && [[ -d "${PWD}/pkg/.aihaus/skills" ]] || return 0
  [[ -n "$(git -C "${PWD}" status --porcelain 2>/dev/null)" ]] || return 0
  echo "aihaus self-update: dogfood cwd has uncommitted changes — aborting (commit or stash manually first)" >&2
  exit 3
}

_help() { cat <<'EOF'
Usage: aihaus <verb> [options]
Verbs:
  install       Install aihaus into the current directory
  update        Update aihaus in the current directory
  memory        Query repository memory (delegates to aih-graph)
                memory packet --task "<text>" --json — batched context packet
                (status + Rule/Decision slice + top matches in ONE call; M050/S05)
  prefs add "<text>" [--topic <slug>]
                Append a global user preference (tier C, M050/S06) to
                ~/.aihaus/memory/user/preferences.md — the SOLE write path
                (ADR-260611-C). Topics: workflow|style|tooling|communication|other
  kanban gate|question|answer
                Sanctioned write path for .aihaus/state/kanban.db (M050/S07,
                ADR-260611-C): gate_events / planning_questions /
                planning_answers rows. Gate validation is WARN-ONLY this cycle
                (ADR-260611-D). Grammar: .aihaus/protocols/kanban/db-schema.md
  feedback export
                Produce .aihaus/runtime/evolution-export.md (M050/S08): gate-churn
                stats (kanban.db gate_events) + recurring warnings
                (warning-recurrence.jsonl) + evolution proposals
                (milestones/*/execution/{AGENT,SKILL}-EVOLUTION.md). Sections
                always present; empty sources carry explicit "(none)" markers.
  update --all  Update all registered installs (~/.aihaus/.targets registry)
  self-update   Update the central aihaus clone from origin (requires Z9)
  --help, -h    Show this message
EOF
}

# ---------------------------------------------------------------------------
# memory packet (M050/S05, ADR-260611-F) — single batched invocation chain.
# Composes three aih-graph calls into ONE shim call so the SubagentStart hook
# makes exactly one `aihaus memory packet` invocation (12s internal hook
# timeout / 15s settings belt). Output shape (architecture.md §4.4):
#   {"status":<status --json>,"rules":<query --types Rule,Decision --top 5>,
#    "matches":<query --top 3>,"degraded":bool,"elapsed_ms":N}
# ---------------------------------------------------------------------------
declare -a GRAPH_RUN=()

_resolve_graph_run() {  # mirrors _memory discovery chain, without exec
  GRAPH_RUN=()
  local ext="" c
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) ext=".exe" ;;
  esac
  local candidates=()
  [[ -n "${AIH_GRAPH_BIN:-}" ]] && candidates+=("${AIH_GRAPH_BIN}")
  candidates+=("$PWD/.aihaus/bin/aih-graph${ext}")
  for c in "${candidates[@]}"; do
    [[ -x "${c}" ]] && GRAPH_RUN=("${c}") && return 0
  done
  if [[ -f "${AIHAUS_HOME}/aih-graph/go.mod" ]] && command -v go >/dev/null 2>&1; then
    local go_tmp_root="${AIH_GRAPH_GO_TMP:-${AIHAUS_HOME}/tmp/aih-graph-go}"
    mkdir -p "${go_tmp_root}/tmp" "${go_tmp_root}/cache" 2>/dev/null || true
    export AIH_GRAPH_CALLER_CWD="${PWD}"
    export GOTMPDIR="${go_tmp_root}/tmp"
    export GOCACHE="${go_tmp_root}/cache"
    GRAPH_RUN=(go -C "${AIHAUS_HOME}/aih-graph" run ./cmd/aih-graph)
    return 0
  fi
  [[ -x "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" ]] && \
    GRAPH_RUN=("${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}") && return 0
  [[ -x "$HOME/.aihaus/bin/aih-graph${ext}" ]] && \
    GRAPH_RUN=("$HOME/.aihaus/bin/aih-graph${ext}") && return 0
  command -v aih-graph >/dev/null 2>&1 && GRAPH_RUN=(aih-graph) && return 0
  return 1
}

_now_ms() {
  local t
  t="$(date +%s%3N 2>/dev/null || echo "")"
  [[ "$t" =~ ^[0-9]+$ ]] || t=$(( $(date +%s 2>/dev/null || echo 0) * 1000 ))
  printf '%s' "$t"
}

_memory_packet() {
  # Receives the db-pinned graph args minus the leading verb.
  local task="" db="" repo=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task)   task="${2:-}"; shift 2 || break ;;
      --task=*) task="${1#--task=}"; shift ;;
      --db|-db)   db="${2:-}"; shift 2 || break ;;
      --db=*)   db="${1#--db=}"; shift ;;
      -db=*)    db="${1#-db=}"; shift ;;
      --repo)   repo="${2:-}"; shift 2 || break ;;
      --repo=*) repo="${1#--repo=}"; shift ;;
      --json)   shift ;;  # packet output is always JSON
      *)        shift ;;
    esac
  done
  if [[ -z "${task}" ]]; then
    echo 'aihaus memory packet: --task "<text>" required' >&2
    exit 2
  fi
  [[ -z "${repo}" ]] && repo="${AIH_GRAPH_REPO:-${CLAUDE_PROJECT_DIR:-$PWD}}"
  _resolve_graph_run || {
    echo "aihaus memory: aih-graph not found. Install it with: bash pkg/scripts/install-aih-graph-binary.sh" >&2
    exit 1
  }
  local db_args=()
  [[ -n "${db}" ]] && db_args=(--db "${db}")
  local start_ms end_ms degraded="false"
  local status_json rules_json matches_json
  start_ms="$(_now_ms)"
  status_json="$("${GRAPH_RUN[@]}" status --repo "${repo}" "${db_args[@]}" --json 2>/dev/null || true)"
  rules_json="$("${GRAPH_RUN[@]}" query --repo "${repo}" "${db_args[@]}" --types Rule,Decision --top 5 --json "${task}" 2>/dev/null || true)"
  matches_json="$("${GRAPH_RUN[@]}" query --repo "${repo}" "${db_args[@]}" --top 3 --json "${task}" 2>/dev/null || true)"
  end_ms="$(_now_ms)"
  # Defensive: any sub-payload that is empty or non-JSON degrades to {}.
  case "${status_json}" in  "{"*) : ;; *) status_json='{}';  degraded="true" ;; esac
  case "${rules_json}" in   "{"*) : ;; *) rules_json='{}';   degraded="true" ;; esac
  case "${matches_json}" in "{"*) : ;; *) matches_json='{}'; degraded="true" ;; esac
  printf '{"status":%s,"rules":%s,"matches":%s,"degraded":%s,"elapsed_ms":%s}\n' \
    "${status_json}" "${rules_json}" "${matches_json}" "${degraded}" "$(( end_ms - start_ms ))"
  exit 0
}

_memory() {
  local ext="" c bin=""
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) ext=".exe" ;;
  esac
  local graph_args=("$@")
  if [[ $# -gt 0 ]]; then
    local cmd="$1"
    shift
    case "$cmd" in
      build|refresh|status|query|context|callers|impact|gotchas|milestone|rule|why|rule-drift|obsidian-export|export-obsidian|packet)
        # db-pin allowlist (BR-P3): every query verb pins --db to the repo DB
        # unless the caller passed one. --user scope is exempt — the user-scope
        # graph lives at ~/.aihaus/state/user-graph.db (ADR-260611-E), never
        # the per-repo DB. `packet` (M050/S05) joins the allowlist to inherit
        # --db defaulting, then is intercepted below (shim-composed verb —
        # aih-graph itself does not know it).
        local has_db=0 user_scope=0 arg repo_root db_path
        for arg in "$@"; do
          [[ "$arg" == "--db" || "$arg" == "-db" || "$arg" == --db=* || "$arg" == -db=* ]] && has_db=1
          [[ "$arg" == "--user" ]] && user_scope=1
        done
        if [[ "$has_db" == "0" && "$user_scope" == "0" ]]; then
          repo_root="${AIH_GRAPH_REPO:-${CLAUDE_PROJECT_DIR:-$PWD}}"
          local expect_repo=0
          for arg in "$@"; do
            if [[ "$expect_repo" == "1" ]]; then
              repo_root="$arg"
              expect_repo=0
              continue
            fi
            case "$arg" in
              --repo) expect_repo=1 ;;
              --repo=*) repo_root="${arg#--repo=}" ;;
            esac
          done
          db_path="${repo_root}/.aihaus/state/aih-graph.db"
          mkdir -p "$(dirname "$db_path")" 2>/dev/null || true
          graph_args=("$cmd" --db "$db_path" "$@")
        else
          graph_args=("$cmd" "$@")
        fi
        ;;
      *)
        graph_args=("$cmd" "$@")
        ;;
    esac
  fi
  # M050/S05: `packet` is composed by the shim (ONE shim call → three
  # aih-graph invocations), never forwarded to the binary.
  if [[ "${graph_args[0]:-}" == "packet" ]]; then
    _memory_packet "${graph_args[@]:1}"
  fi
  local candidates=()
  [[ -n "${AIH_GRAPH_BIN:-}" ]] && candidates+=("${AIH_GRAPH_BIN}")
  candidates+=("$PWD/.aihaus/bin/aih-graph${ext}")
  for c in "${candidates[@]}"; do
    if [[ -x "${c}" ]]; then
      bin="${c}"
      break
    fi
  done
  if [[ -n "${bin}" ]]; then
    exec "${bin}" "${graph_args[@]}"
  fi
  if [[ -f "${AIHAUS_HOME}/aih-graph/go.mod" ]] && command -v go >/dev/null 2>&1; then
    local go_tmp_root="${AIH_GRAPH_GO_TMP:-${AIHAUS_HOME}/tmp/aih-graph-go}"
    mkdir -p "${go_tmp_root}/tmp" "${go_tmp_root}/cache" 2>/dev/null || true
    AIH_GRAPH_CALLER_CWD="${PWD}" \
      GOTMPDIR="${go_tmp_root}/tmp" \
      GOCACHE="${go_tmp_root}/cache" \
      exec go -C "${AIHAUS_HOME}/aih-graph" run ./cmd/aih-graph "${graph_args[@]}"
  fi
  if [[ -x "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" ]]; then
    exec "${AIHAUS_HOME}/aih-graph/bin/aih-graph${ext}" "${graph_args[@]}"
  fi
  if [[ -x "$HOME/.aihaus/bin/aih-graph${ext}" ]]; then
    exec "$HOME/.aihaus/bin/aih-graph${ext}" "${graph_args[@]}"
  fi
  if command -v aih-graph >/dev/null 2>&1; then
    exec aih-graph "${graph_args[@]}"
  fi
  echo "aihaus memory: aih-graph not found. Install it with: bash pkg/scripts/install-aih-graph-binary.sh" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# prefs (M050/S06, ADR-260611-C/E) — tier-C global user preferences.
# `aihaus prefs add "<text>" [--topic <slug>]` is the SOLE write path to
# ~/.aihaus/memory/user/preferences.md (BR-P7 — file-guard keeps blocking
# direct agent Write/Edit; no carve-outs). Atomicity: mkdir-based lock +
# temp file + atomic mv. Own audit JSONL (~/.aihaus/state/prefs-audit.jsonl,
# sole writer — BR-P5). Entry grammar (validated before append):
#   - PREF-<n> [YYYY-MM-DD] (<workflow|style|tooling|communication|other>) <text>
# PREF-<n> allocated by max-scan (business-rules-migrate.sh BR-id shape).
# ---------------------------------------------------------------------------
_PREFS_TS() { date -u +%FT%TZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z"; }

_prefs_audit() {  # _prefs_audit <result> <id> <topic> <reason>
  local audit_dir="$HOME/.aihaus/state"
  local audit_file="${audit_dir}/prefs-audit.jsonl"
  local r_result="${1:-}" r_id="${2:-}" r_topic="${3:-}" r_reason="${4:-}"
  r_reason="${r_reason//\\/\\\\}"; r_reason="${r_reason//\"/\\\"}"
  mkdir -p "${audit_dir}" 2>/dev/null || return 0
  printf '{"ts":"%s","event":"prefs-add","result":"%s","id":"%s","topic":"%s","reason":"%s","shell":"bash"}\n' \
    "$(_PREFS_TS)" "${r_result}" "${r_id}" "${r_topic}" "${r_reason}" \
    >> "${audit_file}" 2>/dev/null || true
}

_prefs_add() {
  local text="" topic="other" arg
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --topic)   topic="${2:-}"; shift 2 || break ;;
      --topic=*) topic="${1#--topic=}"; shift ;;
      *)
        if [[ -z "${text}" ]]; then text="$1"; else text="${text} $1"; fi
        shift ;;
    esac
  done

  # --- Format validation (refusal = non-zero exit + audit row) ---
  # Trim leading/trailing whitespace (pure bash).
  text="${text#"${text%%[![:space:]]*}"}"
  text="${text%"${text##*[![:space:]]}"}"
  if [[ -z "${text}" ]]; then
    _prefs_audit "refused" "" "${topic}" "empty entry text"
    echo 'aihaus prefs add: entry text is empty. Usage: aihaus prefs add "<text>" [--topic <slug>]' >&2
    exit 2
  fi
  case "${text}" in
    *$'\n'*|*$'\r'*)
      _prefs_audit "refused" "" "${topic}" "multi-line entry text"
      echo "aihaus prefs add: entry must be a single line (no embedded newlines)." >&2
      exit 2 ;;
  esac
  if [[ "${#text}" -gt 500 ]]; then
    _prefs_audit "refused" "" "${topic}" "entry text exceeds 500 chars (${#text})"
    echo "aihaus prefs add: entry text exceeds 500 characters (${#text})." >&2
    exit 2
  fi
  case "${topic}" in
    workflow|style|tooling|communication|other) : ;;
    *)
      _prefs_audit "refused" "" "${topic}" "invalid topic (allowed: workflow|style|tooling|communication|other)"
      echo "aihaus prefs add: invalid --topic '${topic}' (allowed: workflow|style|tooling|communication|other)." >&2
      exit 2 ;;
  esac

  local prefs_file="$HOME/.aihaus/memory/user/preferences.md"
  local lock_dir="${prefs_file}.lock"
  mkdir -p "$(dirname "${prefs_file}")" 2>/dev/null || true

  # --- mkdir-based lock (atomic on every POSIX fs; ~10s timeout) ---
  local waited=0
  while ! mkdir "${lock_dir}" 2>/dev/null; do
    waited=$((waited + 1))
    if [[ "${waited}" -ge 100 ]]; then
      _prefs_audit "refused" "" "${topic}" "lock timeout at ${lock_dir}"
      echo "aihaus prefs add: could not acquire lock at ${lock_dir} (stale lock? remove the directory manually and retry)." >&2
      exit 3
    fi
    sleep 0.1 2>/dev/null || sleep 1
  done
  # shellcheck disable=SC2064
  trap "rmdir '${lock_dir}' 2>/dev/null || true" EXIT

  # Seed create-if-absent INSIDE the lock (concurrent first-adds race-safe).
  if [[ ! -f "${prefs_file}" ]]; then
    if [[ -f "${AIHAUS_HOME}/pkg/.aihaus/templates/user-preferences-global.md" ]]; then
      cp "${AIHAUS_HOME}/pkg/.aihaus/templates/user-preferences-global.md" "${prefs_file}" 2>/dev/null || true
    fi
    if [[ ! -f "${prefs_file}" ]]; then
      printf '# User Preferences (aihaus tier C)\n\n<!-- AIHAUS:PREFS-START -->\n## Preferences\n<!-- AIHAUS:PREFS-END -->\n' > "${prefs_file}"
    fi
  fi

  # PREF-<n> max-scan allocation (business-rules-migrate.sh shape).
  local _max next_id
  _max="$(grep -oE '^- PREF-[0-9]+' "${prefs_file}" 2>/dev/null | grep -oE '[0-9]+' | sort -n | tail -1 || true)"
  next_id=$(( ${_max:-0} + 1 ))
  local entry_date entry_line
  entry_date="$(date -u +%F 2>/dev/null || echo 1970-01-01)"
  entry_line="- PREF-${next_id} [${entry_date}] (${topic}) ${text}"

  # Temp file in the same directory + atomic mv. Insert before the END marker
  # when present; append at EOF otherwise.
  local tmp_file="${prefs_file}.tmp.$$"
  if awk -v entry="${entry_line}" '
    index($0, "<!-- AIHAUS:PREFS-END -->") > 0 && !done { print entry; done=1 }
    { print }
    END { if (!done) print entry }
  ' "${prefs_file}" > "${tmp_file}" 2>/dev/null && [[ -s "${tmp_file}" ]]; then
    mv -f "${tmp_file}" "${prefs_file}"
  else
    rm -f "${tmp_file}" 2>/dev/null || true
    rmdir "${lock_dir}" 2>/dev/null || true
    trap - EXIT
    _prefs_audit "refused" "PREF-${next_id}" "${topic}" "temp-file write failed"
    echo "aihaus prefs add: failed to write ${prefs_file}." >&2
    exit 1
  fi

  rmdir "${lock_dir}" 2>/dev/null || true
  trap - EXIT
  _prefs_audit "ok" "PREF-${next_id}" "${topic}" ""
  echo "prefs: appended PREF-${next_id} (${topic}) to ~/.aihaus/memory/user/preferences.md"
  exit 0
}

_prefs() {
  local sub="${1:-}"; shift || true
  case "${sub}" in
    add) _prefs_add "$@" ;;
    *)
      echo 'aihaus prefs: unknown sub-verb. Usage: aihaus prefs add "<text>" [--topic <slug>]' >&2
      exit 2 ;;
  esac
}

# ---------------------------------------------------------------------------
# kanban (M050/S07, ADR-260611-C) — the sanctioned write path for
# .aihaus/state/kanban.db (gate_events / planning_questions / planning_answers).
# The verdict 4-enum + rules_cited grammar are NORMATIVE in
# .aihaus/protocols/kanban/db-schema.md; the citation obligation itself is the
# harness gate law (protocols/harness.md §Gates) — cited here, not restated.
# Gate validation is WARN-ONLY this cycle (ADR-260611-D): malformed shape ⇒
# stderr warn + "warn-allow" audit row + exit 0 — never a block. Every decision
# path (allow / warn-allow / bypass) emits its row BEFORE exiting
# (calibrate-guard decision-ladder shape; bash-guard soft-warn shape).
# .claude/audit/rule-cite.jsonl — THIS wrapper is its SOLE writer (BR-P5),
# rows keyed (task_id, stage, created_at). gate_events schema UNTOUCHED
# (BR-P10): rules_cited persists JSONL-only until the enforce-flip ADR.
# Audited validation bypass: AIHAUS_KANBAN_GATE_VALIDATE=0 (BR-P4, never silent).
# ---------------------------------------------------------------------------
_KANBAN_TS() { date -u +%FT%TZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z"; }

_kanban_repo() { printf '%s' "${CLAUDE_PROJECT_DIR:-$PWD}"; }

_kanban_require_sqlite3() {
  command -v sqlite3 >/dev/null 2>&1 && return 0
  echo "aihaus kanban: sqlite3 not found — the kanban DB requires it (same prerequisite as init-kanban-db.sh). Install sqlite3 and retry." >&2
  exit 127
}

_kanban_db_ensure() {  # _kanban_db_ensure <db_path> — same mkdir guard as the memory db-pin
  local db="$1" repo schema
  mkdir -p "$(dirname "$db")" 2>/dev/null || true
  [[ -f "$db" ]] && return 0
  repo="$(_kanban_repo)"
  for schema in "${repo}/.aihaus/protocols/kanban/schema.sql" \
                "${AIHAUS_HOME}/pkg/.aihaus/protocols/kanban/schema.sql"; do
    if [[ -f "$schema" ]]; then
      sqlite3 "$db" < "$schema" 2>/dev/null || true
      return 0
    fi
  done
  echo "aihaus kanban: no kanban.db at ${db} and no packaged schema.sql found — run .aihaus/protocols/kanban/init-kanban-db.sh first." >&2
  exit 1
}

_kanban_sql() { printf '%s' "$1" | sed "s/'/''/g"; }

_kanban_json_str() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

_kanban_next_id() {  # _kanban_next_id <db> <table> <prefix> — max-scan allocation
  local db="$1" table="$2" prefix="$3" max
  max="$(sqlite3 "$db" "SELECT COALESCE(MAX(CAST(substr(id, $(( ${#prefix} + 1 ))) AS INTEGER)), 0) FROM ${table} WHERE id GLOB '${prefix}[0-9]*';" 2>/dev/null | tr -d '[:space:]' || true)"
  case "$max" in (''|*[!0-9]*) max=0 ;; esac
  printf '%s' $(( max + 1 ))
}

_kanban_gate() {
  local task="" stage="" verdict="" rules="" reason="" evidence="" db=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task)       task="${2:-}"; shift 2 || break ;;
      --task=*)     task="${1#--task=}"; shift ;;
      --stage)      stage="${2:-}"; shift 2 || break ;;
      --stage=*)    stage="${1#--stage=}"; shift ;;
      --verdict)    verdict="${2:-}"; shift 2 || break ;;
      --verdict=*)  verdict="${1#--verdict=}"; shift ;;
      --rules)      rules="${2:-}"; shift 2 || break ;;
      --rules=*)    rules="${1#--rules=}"; shift ;;
      --reason)     reason="${2:-}"; shift 2 || break ;;
      --reason=*)   reason="${1#--reason=}"; shift ;;
      --evidence)   evidence="${2:-}"; shift 2 || break ;;
      --evidence=*) evidence="${1#--evidence=}"; shift ;;
      --db)         db="${2:-}"; shift 2 || break ;;
      --db=*)       db="${1#--db=}"; shift ;;
      *)            shift ;;
    esac
  done
  if [[ -z "$task" || -z "$stage" || -z "$verdict" ]]; then
    echo 'aihaus kanban gate: --task <id> --stage <stage> --verdict "<verdict>" required ([--rules <csv>] [--reason <text>] [--evidence <path>] [--db <path>])' >&2
    exit 2
  fi

  # --- Shape validation (WARN-ONLY; grammar normative in db-schema.md) ------
  local validation="ok" warn_reason="" decision="allow" opt_out="false"
  if [[ "${AIHAUS_KANBAN_GATE_VALIDATE:-1}" == "0" ]]; then
    decision="bypass"; opt_out="true"
  else
    if ! printf '%s' "$verdict" | grep -qE '^(PASS|SKIPPED|BLOCKED-TO-PLANNING|BLOCKED)(:.*)?$'; then
      validation="warn"
      warn_reason="verdict '${verdict}' not in 4-enum PASS|SKIPPED|BLOCKED-TO-PLANNING|BLOCKED"
    fi
    if [[ -z "$rules" ]]; then
      validation="warn"
      warn_reason="${warn_reason:+${warn_reason}; }rules_cited missing — cite per the harness gate law (protocols/harness.md)"
    else
      local _ifs_save="$IFS" el bad=""
      IFS=','
      for el in $rules; do
        el="${el#"${el%%[![:space:]]*}"}"; el="${el%"${el##*[![:space:]]}"}"
        [[ -z "$el" ]] && { bad="${bad:+${bad} }'<empty>'"; continue; }
        printf '%s' "$el" | grep -qE '^(BR-F?[0-9]+|GAP:pq-[A-Za-z0-9][A-Za-z0-9_-]*|MECHANICS)$' || bad="${bad:+${bad} }'${el}'"
      done
      IFS="$_ifs_save"
      if [[ -n "$bad" ]]; then
        validation="warn"
        warn_reason="${warn_reason:+${warn_reason}; }rules_cited element(s) ${bad} not in grammar BR-F?[0-9]+ | GAP:pq-<id> | MECHANICS"
      fi
    fi
    [[ "$validation" == "warn" ]] && decision="warn-allow"
  fi
  if [[ "$decision" == "warn-allow" ]]; then
    echo "aihaus kanban gate: WARN — ${warn_reason}. Recorded warn-allow; the write proceeds (warn-only this cycle, ADR-260611-D). Grammar: .aihaus/protocols/kanban/db-schema.md. Audited bypass: AIHAUS_KANBAN_GATE_VALIDATE=0." >&2
  fi

  # --- Persist the kanban row (gate_events schema UNTOUCHED — BR-P10) -------
  _kanban_require_sqlite3
  local repo; repo="$(_kanban_repo)"
  [[ -z "$db" ]] && db="${repo}/.aihaus/state/kanban.db"
  _kanban_db_ensure "$db"
  local created_at gid reason_sql="NULL" evidence_sql="NULL"
  created_at="$(_KANBAN_TS)"
  gid="$(printf 'GATE-%03d' "$(_kanban_next_id "$db" gate_events "GATE-")")"
  [[ -n "$reason" ]] && reason_sql="'$(_kanban_sql "$reason")'"
  [[ -n "$evidence" ]] && evidence_sql="'$(_kanban_sql "$evidence")'"
  if ! sqlite3 "$db" "INSERT INTO gate_events (id, task_id, stage, verdict, reason, evidence_path, created_at) VALUES ('$(_kanban_sql "$gid")', '$(_kanban_sql "$task")', '$(_kanban_sql "$stage")', '$(_kanban_sql "$verdict")', ${reason_sql}, ${evidence_sql}, '${created_at}');" 2>/dev/null; then
    echo "aihaus kanban gate: failed to write gate_events row to ${db}." >&2
    exit 1
  fi

  # --- Citation row → rule-cite.jsonl (SOLE writer — BR-P5) -----------------
  local audit_dir="${repo}/.claude/audit" rules_json="" warn_json="null" el2
  mkdir -p "$audit_dir" 2>/dev/null || true
  if [[ -n "$rules" ]]; then
    local _ifs_save2="$IFS"
    IFS=','
    for el2 in $rules; do
      el2="${el2#"${el2%%[![:space:]]*}"}"; el2="${el2%"${el2##*[![:space:]]}"}"
      [[ -z "$el2" ]] && continue
      rules_json="${rules_json:+${rules_json},}\"$(_kanban_json_str "$el2")\""
    done
    IFS="$_ifs_save2"
  fi
  [[ -n "$warn_reason" ]] && warn_json="\"$(_kanban_json_str "$warn_reason")\""
  printf '{"ts":"%s","event":"kanban-gate","task_id":"%s","stage":"%s","created_at":"%s","verdict":"%s","rules_cited":[%s],"validation":"%s","warn_reason":%s,"decision":"%s","opt_out":%s,"shell":"bash"}\n' \
    "${created_at}" "$(_kanban_json_str "$task")" "$(_kanban_json_str "$stage")" "${created_at}" \
    "$(_kanban_json_str "$verdict")" "${rules_json}" "${validation}" "${warn_json}" "${decision}" "${opt_out}" \
    >> "${audit_dir}/rule-cite.jsonl" 2>/dev/null || true
  echo "kanban: gate ${verdict%%:*} recorded for ${task}@${stage} (${gid}; decision ${decision})"
  exit 0
}

_kanban_question() {
  local task="" question="" reason="" qid="" source_kind="local" source_ref="" db=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task)          task="${2:-}"; shift 2 || break ;;
      --task=*)        task="${1#--task=}"; shift ;;
      --question)      question="${2:-}"; shift 2 || break ;;
      --question=*)    question="${1#--question=}"; shift ;;
      --reason)        reason="${2:-}"; shift 2 || break ;;
      --reason=*)      reason="${1#--reason=}"; shift ;;
      --id)            qid="${2:-}"; shift 2 || break ;;
      --id=*)          qid="${1#--id=}"; shift ;;
      --source-kind)   source_kind="${2:-}"; shift 2 || break ;;
      --source-kind=*) source_kind="${1#--source-kind=}"; shift ;;
      --source-ref)    source_ref="${2:-}"; shift 2 || break ;;
      --source-ref=*)  source_ref="${1#--source-ref=}"; shift ;;
      --db)            db="${2:-}"; shift 2 || break ;;
      --db=*)          db="${1#--db=}"; shift ;;
      *)               shift ;;
    esac
  done
  if [[ -z "$task" || -z "$question" ]]; then
    echo 'aihaus kanban question: --task <id> --question "<one task-specific business-rule gap>" required ([--reason <text>] [--id pq-<n>] [--source-kind <kind>] [--source-ref <ref>] [--db <path>])' >&2
    exit 2
  fi
  if [[ -n "$qid" ]] && ! printf '%s' "$qid" | grep -qE '^pq-[A-Za-z0-9][A-Za-z0-9_-]*$'; then
    echo "aihaus kanban question: --id '${qid}' must match pq-<id> (grammar: .aihaus/protocols/kanban/db-schema.md)." >&2
    exit 2
  fi
  _kanban_require_sqlite3
  local repo; repo="$(_kanban_repo)"
  [[ -z "$db" ]] && db="${repo}/.aihaus/state/kanban.db"
  _kanban_db_ensure "$db"
  [[ -z "$qid" ]] && qid="$(printf 'pq-%03d' "$(_kanban_next_id "$db" planning_questions "pq-")")"
  local asked_at reason_sql="NULL" sref_sql="NULL"
  asked_at="$(_KANBAN_TS)"
  [[ -n "$reason" ]] && reason_sql="'$(_kanban_sql "$reason")'"
  [[ -n "$source_ref" ]] && sref_sql="'$(_kanban_sql "$source_ref")'"
  if ! sqlite3 "$db" "INSERT INTO planning_questions (id, task_id, question, reason, status, source_kind, source_ref, asked_at) VALUES ('$(_kanban_sql "$qid")', '$(_kanban_sql "$task")', '$(_kanban_sql "$question")', ${reason_sql}, 'open', '$(_kanban_sql "$source_kind")', ${sref_sql}, '${asked_at}');" 2>/dev/null; then
    echo "aihaus kanban question: failed to write planning_questions row to ${db} (duplicate id ${qid}?)." >&2
    exit 1
  fi
  echo "kanban: planning question ${qid} recorded for ${task} (status open)"
  exit 0
}

_kanban_answer() {
  local qid="" answer="" source_kind="local" source_ref="" db=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --question)      qid="${2:-}"; shift 2 || break ;;
      --question=*)    qid="${1#--question=}"; shift ;;
      --answer)        answer="${2:-}"; shift 2 || break ;;
      --answer=*)      answer="${1#--answer=}"; shift ;;
      --source-kind)   source_kind="${2:-}"; shift 2 || break ;;
      --source-kind=*) source_kind="${1#--source-kind=}"; shift ;;
      --source-ref)    source_ref="${2:-}"; shift 2 || break ;;
      --source-ref=*)  source_ref="${1#--source-ref=}"; shift ;;
      --db)            db="${2:-}"; shift 2 || break ;;
      --db=*)          db="${1#--db=}"; shift ;;
      *)               shift ;;
    esac
  done
  if [[ -z "$qid" || -z "$answer" ]]; then
    echo 'aihaus kanban answer: --question <pq-id> --answer "<text>" required ([--source-kind <kind>] [--source-ref <ref>] [--db <path>]). A "no-rule:<reason>" answer records an explicit promotion waiver.' >&2
    exit 2
  fi
  _kanban_require_sqlite3
  local repo; repo="$(_kanban_repo)"
  [[ -z "$db" ]] && db="${repo}/.aihaus/state/kanban.db"
  _kanban_db_ensure "$db"
  local exists
  exists="$(sqlite3 "$db" "SELECT count(*) FROM planning_questions WHERE id = '$(_kanban_sql "$qid")';" 2>/dev/null | tr -d '[:space:]' || true)"
  if [[ "$exists" == "0" ]]; then
    echo "aihaus kanban answer: question ${qid} not found in ${db} — record it first via: aihaus kanban question" >&2
    exit 4
  fi
  local aid answered_at qstatus="answered" sref_sql="NULL"
  case "$answer" in no-rule:*) qstatus="waived" ;; esac
  aid="$(printf 'pa-%03d' "$(_kanban_next_id "$db" planning_answers "pa-")")"
  answered_at="$(_KANBAN_TS)"
  [[ -n "$source_ref" ]] && sref_sql="'$(_kanban_sql "$source_ref")'"
  if ! sqlite3 "$db" "INSERT INTO planning_answers (id, question_id, answer, source_kind, source_ref, answered_at) VALUES ('$(_kanban_sql "$aid")', '$(_kanban_sql "$qid")', '$(_kanban_sql "$answer")', '$(_kanban_sql "$source_kind")', ${sref_sql}, '${answered_at}'); UPDATE planning_questions SET status = '${qstatus}', answered_at = '${answered_at}' WHERE id = '$(_kanban_sql "$qid")';" 2>/dev/null; then
    echo "aihaus kanban answer: failed to write planning_answers row to ${db}." >&2
    exit 1
  fi
  echo "kanban: answer ${aid} recorded for ${qid} (question status ${qstatus})"
  if [[ "$qstatus" == "answered" ]]; then
    echo "kanban: promote it to a DRAFT business rule carrying 'Source: ${qid}' per .aihaus/protocols/kanban/memory-promotion.md (the eval planning-answer-promotion join checks this)"
  fi
  exit 0
}

_kanban() {
  local sub="${1:-}"; shift || true
  case "${sub}" in
    gate)     _kanban_gate "$@" ;;
    question) _kanban_question "$@" ;;
    answer)   _kanban_answer "$@" ;;
    *)
      echo 'aihaus kanban: unknown sub-verb. Usage: aihaus kanban gate|question|answer (grammar: .aihaus/protocols/kanban/db-schema.md, ADR-260611-C)' >&2
      exit 2 ;;
  esac
}

# ---------------------------------------------------------------------------
# feedback (M050/S08) — evolution-feedback export. Produces
# .aihaus/runtime/evolution-export.md with THREE sections, each ALWAYS
# present (never silently absent): empty sources carry an explicit "(none —
# <reason>)" marker. Read-only over every source (BR-P5 — kanban.db,
# warning-recurrence.jsonl and the EVOLUTION ledgers keep their own writers).
#   1. Gate-churn stats        — kanban.db gate_events (sqlite3 + DB required)
#   2. Recurring warnings      — .claude/audit/warning-recurrence.jsonl
#   3. Evolution proposals     — .aihaus/milestones/*/execution/{AGENT,SKILL}-EVOLUTION.md
# ---------------------------------------------------------------------------
_feedback_export() {
  local repo out ts
  repo="${CLAUDE_PROJECT_DIR:-$PWD}"
  out="${repo}/.aihaus/runtime/evolution-export.md"
  mkdir -p "$(dirname "$out")" 2>/dev/null || {
    echo "aihaus feedback export: cannot create $(dirname "$out")" >&2
    exit 1
  }
  ts="$(date -u +%FT%TZ 2>/dev/null || echo "1970-01-01T00:00:00Z")"

  # --- Section 1: gate-churn stats (kanban.db gate_events) -------------------
  local gate_section="(none — no kanban.db at .aihaus/state/kanban.db)"
  local db="${repo}/.aihaus/state/kanban.db"
  if [[ -f "$db" ]]; then
    if command -v sqlite3 >/dev/null 2>&1; then
      local gate_rows totals
      gate_rows="$(sqlite3 -separator ' | ' "$db" \
        "SELECT stage, verdict, COUNT(*) FROM gate_events GROUP BY stage, verdict ORDER BY stage, verdict;" 2>/dev/null || true)"
      if [[ -n "$gate_rows" ]]; then
        totals="$(sqlite3 -separator ' ' "$db" \
          "SELECT COUNT(*), COUNT(DISTINCT task_id) FROM gate_events;" 2>/dev/null || true)"
        gate_section="| stage | verdict | count |
|-------|---------|-------|
$(printf '%s\n' "$gate_rows" | awk -F' \\| ' '{printf "| %s | %s | %s |\n", $1, $2, $3}')

Totals: ${totals%% *} gate event(s) across ${totals##* } distinct task(s)."
      else
        gate_section="(none — kanban.db present but gate_events is empty)"
      fi
    else
      gate_section="(none — kanban.db present but sqlite3 unavailable)"
    fi
  fi

  # --- Section 2: recurring warnings (warning-recurrence.jsonl) --------------
  local warn_section="(none — no .claude/audit/warning-recurrence.jsonl)"
  local recurrence_log="${repo}/.claude/audit/warning-recurrence.jsonl"
  if [[ -f "$recurrence_log" ]]; then
    if command -v jq >/dev/null 2>&1; then
      local warn_rows
      warn_rows="$(jq -r '
        "- [" + (.category // "unknown") + "] " + (.source_agent // "unknown") +
        " (x" + ((.recurrence_count // 0) | tostring) + ", " +
        (.first_seen_milestone // "?") + " -> " + (.last_seen_milestone // "?") + "): " +
        ((.summary_representative // "") | .[0:200])
      ' "$recurrence_log" 2>/dev/null || true)"
      if [[ -n "$warn_rows" ]]; then
        warn_section="$warn_rows"
      else
        warn_section="(none — warning-recurrence.jsonl present but empty)"
      fi
    else
      # jq-less fallback: surface the raw rows rather than dropping the section.
      warn_section="jq unavailable — raw rows (first 50):

\`\`\`
$(head -50 "$recurrence_log" 2>/dev/null || true)
\`\`\`"
    fi
  fi

  # --- Section 3: evolution proposals (milestone EVOLUTION ledgers) ----------
  local evo_section="" evo_file evo_rel evo_lines
  for evo_file in "${repo}"/.aihaus/milestones/*/execution/AGENT-EVOLUTION.md \
                  "${repo}"/.aihaus/milestones/*/execution/SKILL-EVOLUTION.md; do
    [[ -f "$evo_file" ]] || continue
    evo_rel="${evo_file#"${repo}"/}"
    evo_lines="$(wc -l < "$evo_file" 2>/dev/null | tr -d ' ' || echo 0)"
    evo_section="${evo_section}- \`${evo_rel}\` (${evo_lines} lines)
"
  done
  [[ -z "$evo_section" ]] && evo_section="(none — no .aihaus/milestones/*/execution/{AGENT,SKILL}-EVOLUTION.md found)"

  cat > "$out" <<EXPORT_EOF
# Evolution export (aihaus feedback export, M050/S08)

Generated: ${ts}
Repo: ${repo}
Sources are read-only; this file is regenerated on every run.

## Gate-churn stats

${gate_section}

## Recurring warnings

${warn_section}

## Evolution proposals

${evo_section}
EXPORT_EOF
  echo "feedback: wrote ${out}"
  exit 0
}

_feedback() {
  local sub="${1:-}"; shift || true
  case "${sub}" in
    export) _feedback_export "$@" ;;
    *)
      echo 'aihaus feedback: unknown sub-verb. Usage: aihaus feedback export' >&2
      exit 2 ;;
  esac
}

VERB="${1:-}"; shift || true
case "${VERB}" in --help|-h|"") _help; exit 0 ;; esac

AIHAUS_HOME="$(_resolve)" || { echo "aihaus: package not found. Set AIHAUS_HOME or reinstall." >&2; exit 1; }
export AIHAUS_HOME

case "${VERB}" in
  install)
    exec bash "${AIHAUS_HOME}/pkg/scripts/install.sh" --target "${PWD}" "$@" ;;
  update)
    if [[ "${1:-}" == "--all" ]]; then shift
      reg="$HOME/.aihaus/.targets"
      if [[ ! -f "${reg}" ]]; then
        echo "aihaus update --all: registry not yet populated (~/.aihaus/.targets; written by install/update since M050/S08 — run an install or update on a repo first)." >&2
        exit 1; fi
      rc=0
      while IFS= read -r t || [[ -n "${t}" ]]; do
        [[ -z "${t}" ]] && continue
        echo "aihaus update: ${t}"
        bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --target "${t}" "$@" || rc=$?
      done < "${reg}"; exit "${rc}"
    fi
    exec bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --target "${PWD}" "$@" ;;
  memory)
    _memory "$@" ;;
  prefs)
    _prefs "$@" ;;
  kanban)
    _kanban "$@" ;;
  feedback)
    _feedback "$@" ;;
  self-update)
    _dogfood_dirty
    exec bash "${AIHAUS_HOME}/pkg/scripts/update.sh" --self "$@" ;;
  *)
    echo "aihaus: unknown verb '${VERB}'" >&2; echo "Run 'aihaus --help' for usage." >&2; exit 2 ;;
esac
