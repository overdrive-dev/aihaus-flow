{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "AIHAUS_AUTONOMY_HAIKU": "1"
  },
  "aihaus": {
    "suppress": {
      "taskCreateReminder": true
    },
    "audit": {
      "gateLogPath": ".claude/audit/autonomy-gate.jsonl",
      "rotateSizeMB": 10,
      "rotateLines": 10000,
      "haikuRateWindowSec": 30,
      "cacheTtlSec": 300
    }
  },
  "additionalDirectories": [
    ".aihaus",
    ".claude"
  ],
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/statusline-milestone.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/session-start.sh",
            "statusMessage": "Loading project context..."
          },
          {
            "type": "command",
            "command": "AIHAUS_CONTEXT_REFRESH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/project-context-refresh.sh --reason startup",
            "timeout": 60,
            "async": true
          },
          {
            "type": "command",
            "command": "AIH_GRAPH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-refresh.sh",
            "timeout": 300,
            "async": true
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "aih-feature|aih-milestone",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/calibrate-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking calibration gate..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/bash-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking command safety..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/git-add-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking git stage safety..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/role-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking role capability boundary..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/flow-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking promotion-boundary flow..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/file-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking file safety..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/read-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/backup-file.sh",
            "async": true,
            "statusMessage": "Backing up..."
          },
          {
            "type": "command",
            "command": "AIH_GRAPH_STALE_REASON=write-edit bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-stale.sh --reason write-edit",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/audit-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-stale.sh --from-hook bash",
            "async": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/task-created.sh",
            "timeout": 10,
            "statusMessage": "Validating task..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/task-completed.sh",
            "timeout": 30,
            "statusMessage": "Verifying completion..."
          },
          {
            "type": "command",
            "command": "AIHAUS_CONTEXT_REFRESH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/project-context-refresh.sh --reason task-completed",
            "timeout": 60,
            "async": true
          },
          {
            "type": "command",
            "command": "AIH_GRAPH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-refresh.sh",
            "timeout": 300,
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/teammate-idle.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/context-inject.sh",
            "timeout": 15,
            "statusMessage": "Injecting context..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/audit-agent.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/learning-advisor.sh",
            "timeout": 10,
            "statusMessage": "Capturing learning..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/warning-recurrence.sh",
            "timeout": 30,
            "statusMessage": "Aggregating warning recurrence..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/worktree-release.sh",
            "timeout": 30,
            "statusMessage": "Releasing worktree lock (L1)..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/session-end.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/worktree-release-all.sh",
            "timeout": 60,
            "statusMessage": "Releasing session worktrees (L2)..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "AIHAUS_CONTEXT_REFRESH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/project-context-refresh.sh --reason session-end",
            "timeout": 60,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "AIH_GRAPH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-refresh.sh",
            "timeout": 300,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/autonomy-guard.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
