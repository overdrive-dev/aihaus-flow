{
  "hooks": {
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/task-created.sh"}
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/task-completed.sh"}
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {"type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/learning-advisor.sh"}
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "aih-feature|aih-milestone",
        "hooks": [
          {"type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/calibrate-guard.sh"}
        ]
      }
    ]
  }
}
