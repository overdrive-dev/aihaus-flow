{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/session-start.sh",
            "statusMessage": "Loading project context..."
          },
          {
            "type": "command",
            "command": "AIH_GRAPH_QUIET=1 bash \"$CLAUDE_PROJECT_DIR\"/.aihaus/hooks/aih-graph-refresh.sh",
            "timeout": 300,
            "async": true
          }
        ]
      }
    ]
  }
}
